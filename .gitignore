# raw data - never commit the Kaggle dataset
data/raw/*
!data/raw/.gitkeep
data/*.duckdb
data/*.duckdb.wal

# dbt
warehouse/target/
warehouse/dbt_packages/
warehouse/logs/
warehouse/.user.yml

# modeling artifacts (regenerated by the pipeline) - repo root only.
# MUST be anchored with a leading slash: an unanchored "models/" here
# previously matched warehouse/models/ too, at any depth, silently excluding
# the entire dbt project (every model .sql/.yml file) from every commit.
/models/
/reports/

# synthetic test fixtures (regenerated by tests/generate_synthetic_data.py)
tests/fixtures/

# mlflow
/mlruns/
/mlartifacts/
/mlflow.db

# python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/
venv/
.ruff_cache/
/build/
*.egg-info

# os / editor
.DS_Store
.vscode/
.idea/
